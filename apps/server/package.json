{
  "name": "@game-platform/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/db/migrate.ts && tsx watch src/index.ts",
    "build": "npx rimraf dist && tsc -b --force",
    "start": "node dist/db/migrate.js && node dist/index.js",
    "typecheck": "tsc -b --pretty false",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:seed:games": "tsx src/scripts/seed-games.ts",
    "sms:test": "tsx src/scripts/test-sms.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@game-platform/shared": "*",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "livekit-client": "^2.18.8",
    "livekit-server-sdk": "^2.15.2",
    "mediasoup": "^3.20.0",
    "melipayamak-api": "^0.1.0",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
